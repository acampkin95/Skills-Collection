## Auth.js v5 setup patterns

Auth.js v5 centralizes configuration in a root `auth.ts` file that exports `auth`, `handlers`, `signIn`, and `signOut`. The handlers pattern simplifies route setup:

```typescript
// auth.ts
import NextAuth from "next-auth"
import GitHub from "next-auth/providers/github"
import { PrismaAdapter } from "@auth/prisma-adapter"
import { prisma } from "@/lib/prisma"

export const { auth, handlers, signIn, signOut } = NextAuth({
  adapter: PrismaAdapter(prisma),
  session: { strategy: "jwt" }, // Required for Credentials provider
  providers: [
    GitHub, // Auto-infers AUTH_GITHUB_ID and AUTH_GITHUB_SECRET
  ],
  callbacks: {
    jwt({ token, user }) {
      if (user) {
        token.id = user.id
        token.role = user.role
      }
      return token
    },
    session({ session, token }) {
      session.user.id = token.id as string
      session.user.role = token.role as string
      return session
    },
  },
})

// app/api/auth/[...nextauth]/route.ts
export { GET, POST } from "@/auth"
```

For **Edge runtime compatibility**, split configuration into `auth.config.ts` (Edge-safe, no database) and `auth.ts` (full config with adapter). Middleware uses only the Edge-safe config:

```typescript
// middleware.ts
import NextAuth from "next-auth"
import authConfig from "./auth.config"

export default NextAuth(authConfig).auth((req) => {
  if (!req.auth && req.nextUrl.pathname !== "/login") {
    return Response.redirect(new URL("/login", req.nextUrl))
  }
})
```

Session access in Server Components and Server Actions uses the `auth()` function directly—no more `getServerSession(authOptions)` boilerplate.

